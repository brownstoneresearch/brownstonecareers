{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "brownstone-careers",
  "main": "./src/index.js",
  "compatibility_date": "2026-07-17",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "secrets": {
    "required": ["RESEND_API_KEY", "EMAIL_FROM", "RECRUITMENT_EMAIL"]
  }
}
